{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodePulse",
  "version": "1.2.0",
  "identifier": "com.lingling.CodePulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodePulse",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerBundleIdentifier": null,
      "signingConfig": null
    },
    "linux": {
      "deb": {
        "depends": [
          "webkit2gtk-4.1",
          "libjavascriptcoregtk-4.1-1",
          "libgtk-3-0",
          "libsoup-3.0-0"
        ]
      },
      "appImage": {
        "bundleMediaFramework": false
      }
    }
  }
}
